# jarvis-phone-gateway — bootstrap + secrets only.
# Non-secret runtime config belongs in the settings DB (phone_calls.* keys,
# owned by CC). See CLAUDE.md.

# --- Telephony (GATEWAY-ONLY secrets — never the settings DB, never CC).
# The auth token is doubly sensitive: it is also the signature-verification
# key for inbound media-stream upgrades. Rotating it invalidates in-flight
# signature checks.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public HTTPS base of THIS worker (named Cloudflare tunnel hostname — never
# quick tunnels; see the PRD infra prereq). The wss URL in TwiML and the
# signature check both derive from it.
PUBLIC_URL=

# --- Jarvis stack
JARVIS_CONFIG_URL=http://localhost:7700
JARVIS_APP_ID=
JARVIS_APP_KEY=
CC_BASE_URL=http://localhost:7703
WHISPER_URL=http://localhost:7706
LLM_URL=http://localhost:7704
TTS_URL=http://localhost:7707
REDIS_URL=redis://localhost:6379/0

# --- Server
SERVER_HOST=0.0.0.0
SERVER_PORT=7713

# --- Tuning (spike-validated default; telephone speech measured ~2650-3100 RMS)
VAD_RMS=250
